  echo ""
  echo "是否现在给这个中转绑定入站节点？"
  echo " [1] 新增入站节点并使用此中转"
  echo " [2] 选择已有入站节点使用此中转"
  echo " [0] 暂不绑定"
  printf "\033[32m请选择 [0]: \033[0m"
