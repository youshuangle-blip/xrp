main(){
  need_root; init_dirs
  while true; do
    menu
    read -r CHOICE
    case "$CHOICE" in
      1) add_node; pause ;;
      2) list_nodes; pause ;;
      3) show_links; pause ;;
      4) delete_node; pause ;;
      5) change_node_port; pause ;;
      6) svc_start; pause ;;
      7) svc_stop; pause ;;
      8) svc_status; pause ;;
      9) svc_logs; pause ;;
      10) install_xray; pause ;;
      11) install_singbox; pause ;;
      12) update_panel ;;
      13) uninstall_panel; pause ;;
      14) realm_menu; pause ;;
      15) core_route_menu ;;
      0) exit 0 ;;
      *) red "无效选择"; pause ;;
    esac
  done
}

