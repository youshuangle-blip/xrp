add_node(){
  _bind_relay_tag="${1:-}"
  _bind_relay_mode="${2:-direct}"
  need_root; init_dirs
  singbox_bin >/dev/null 2>&1 || { yellow "未检测到 sing-box，先安装核心。"; install_singbox || return; }
  ensure_python || { red "需要 python3 才能生成配置。"; return; }
  line
  green "添加节点"
  echo " [1] VLESS Reality"
  echo " [2] Shadowsocks"
  echo " [3] SOCKS5"
  printf "\033[32m请选择 [1]: \033[0m"
  read -r T
  [ -z "$T" ] && T=1
  echo "已选择：$T"
  yellow "正在检测服务器公网 IP..."
  DETECT_IP="$(get_public_ip)"
  [ -n "$DETECT_IP" ] && green "检测到公网 IP：$DETECT_IP" || yellow "未检测到公网 IP，请手动输入。"
  NODE_ID="$(rand_hex 4)"
  NODE_TAG="node_$NODE_ID"
  PUBLIC_HOST="$(ask_required "客户端连接地址/域名" "$DETECT_IP")"
  LISTEN_PORT="$(ask_listen_port "服务监听端口" "$(rand_port)")"
  EXT_PORT="$(ask "客户端连接端口" "$LISTEN_PORT")"
  if [ -n "$_bind_relay_tag" ] && [ "$_bind_relay_mode" != "direct" ]; then
    NODE_RELAY_MODE="$_bind_relay_mode"; NODE_RELAY_TAG="$_bind_relay_tag"
  else
    NODE_RELAY_MODE="direct"; NODE_RELAY_TAG=""
  fi
  SNI=""; UUID=""; PRIVATE_KEY=""; PUBLIC_KEY=""; SHORT_ID=""; METHOD=""; PASSWORD=""; SOCKS_USER=""
  case "$T" in
    1)
      NODE_TYPE="vless"
      NODE_NAME="$(ask_name "节点名称" "vless-$EXT_PORT")"
      SNI="$(ask_sni "Reality SNI/握手域名" "www.microsoft.com")"
      UUID="$(gen_uuid)"
      if ! gen_x25519; then red "生成 Reality 密钥失败。"; return; fi
      SHORT_ID="$(rand_hex 8)"
      ;;
    2)
      NODE_TYPE="ss"
      NODE_NAME="$(ask_name "节点名称" "ss-$EXT_PORT")"
      echo "常用加密：chacha20-ietf-poly1305 / aes-128-gcm / aes-256-gcm"
      METHOD="$(ask "加密方式" "chacha20-ietf-poly1305")"
      PASSWORD="$(ask "密码" "$(rand_hex 12)")"
      ;;
    3)
      NODE_TYPE="socks"
      NODE_NAME="$(ask_name "节点名称" "socks-$EXT_PORT")"
      SOCKS_USER="$(ask_name "用户名" "socks")"
      PASSWORD="$(ask "密码" "$(rand_hex 8)")"
      ;;
    *) red "选择无效。"; return ;;
  esac
  write_node
  if [ -n "$NODE_RELAY_TAG" ]; then
    green "节点已添加，并已绑定中转 $NODE_RELAY_TAG。"
  else
    green "节点已添加，默认本机直出。"
  fi
  line
  echo "节点链接/参数："
  node_link "$NODES_DIR/$NODE_ID.env"
  if CLASH_FILE="$(save_node_clash_file "$NODES_DIR/$NODE_ID.env")"; then
    echo "Clash 配置文件：$CLASH_FILE"
  fi
  apply_config_silent
}

