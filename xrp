      green "节点已绑定中转 $_relay_tag。"
      apply_config_silent
      ;;
    0)
      yellow "已暂不绑定，可稍后在“设置节点中转”中选择。"
      ;;
    *) red "选择无效。" ;;
  esac
}

add_relay(){
  init_dirs
  line; green "添加中转"
  reset_relay_vars
  RELAY_ID="$(rand_hex 4)"
  RELAY_TAG="relay_$RELAY_ID"
  RELAY_LINK="$(ask "节点链接（可选，支持 ss://、socks://、vless://；留空手动填写）" "")"
  if [ -n "$RELAY_LINK" ]; then
    ensure_python || { red "需要 python3 才能解析节点链接。"; return; }
    PARSED_LINK="$(parse_relay_link "$RELAY_LINK")" || { red "链接解析失败，请检查链接格式。"; return; }
    eval "$PARSED_LINK"
    RELAY_TYPE="$LINK_RELAY_TYPE"
    SERVER="$LINK_SERVER"
    PORT="$LINK_PORT"
    METHOD="$LINK_METHOD"
    PASSWORD="$LINK_PASSWORD"
    SOCKS_USER="$LINK_SOCKS_USER"
    UUID="$LINK_UUID"
    SNI="$LINK_SNI"
    PUBLIC_KEY="$LINK_PUBLIC_KEY"
    SHORT_ID="$LINK_SHORT_ID"
    FLOW="$LINK_FLOW"
    TRANSPORT="$LINK_TRANSPORT"
    SECURITY="$LINK_SECURITY"
    FINGERPRINT="$LINK_FINGERPRINT"
    WS_HOST="$LINK_WS_HOST"
    WS_PATH="$LINK_WS_PATH"
    SERVICE_NAME="$LINK_SERVICE_NAME"
    ALPN="$LINK_ALPN"
    SPIDER_X="$LINK_SPIDER_X"
    DEFAULT_NAME="$RELAY_TYPE-relay-$RELAY_ID"
    [ -n "${LINK_NAME:-}" ] && DEFAULT_NAME="$(safe_name "$LINK_NAME" "$DEFAULT_NAME")"
    RELAY_NAME="$(ask_name "名称" "$DEFAULT_NAME")"
    green "已识别：$RELAY_TYPE $SERVER:$PORT"
  else
    echo " [1] Shadowsocks"
    echo " [2] SOCKS5"
    printf "\033[32m请选择 [1]: \033[0m"
    read -r R
    [ -z "$R" ] && R=1
    case "$R" in
      1)
        RELAY_TYPE="ss"
        RELAY_NAME="$(ask_name "名称" "ss-relay-$RELAY_ID")"
        SERVER="$(ask_required "SS 地址/IP" "")"
        PORT="$(ask_required "SS 端口" "")"
        echo "常用加密：chacha20-ietf-poly1305 / aes-128-gcm / aes-256-gcm"
        METHOD="$(ask "SS 加密方式" "chacha20-ietf-poly1305")"
        PASSWORD="$(ask_required "SS 密码" "")"
        ;;
      2)
        RELAY_TYPE="socks"
        RELAY_NAME="$(ask_name "名称" "socks-relay-$RELAY_ID")"
        SERVER="$(ask_required "SOCKS5 地址/IP" "")"
        PORT="$(ask_required "SOCKS5 端口" "")"
        SOCKS_USER="$(ask_name "SOCKS5 用户名，没有就直接回车" "")"
        [ -n "$SOCKS_USER" ] && PASSWORD="$(ask_required "SOCKS5 密码" "")" || PASSWORD=""
        ;;
      *) red "选择无效。"; return ;;
    esac
  fi
  write_relay
  green "中转已添加。"
  bind_relay_after_add "$RELAY_TAG"
}

list_relays(){
