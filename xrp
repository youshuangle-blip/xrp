# 监听端口查重：占用返回 0，未占用返回 1
# $1 = 待检端口   $2 = 需排除的节点文件（编辑现有节点时传自身）
port_in_use(){
  _p="$1"; _exclude="${2:-}"
  for nf in "$NODES_DIR"/*.env; do
    [ -f "$nf" ] || continue
    [ "$nf" = "$_exclude" ] && continue
    # shellcheck disable=SC1090
    _lp="$(. "$nf" 2>/dev/null; printf "%s" "${LISTEN_PORT:-}")"
    [ "$_lp" = "$_p" ] && return 0
  done
  for cf in "$CORE_ROUTES_DIR"/*.env; do
    [ -f "$cf" ] || continue
    [ "$cf" = "$_exclude" ] && continue
    # shellcheck disable=SC1090
    _cp="$(. "$cf" 2>/dev/null; printf "%s" "${LISTEN_PORT:-}")"
    [ "$_cp" = "$_p" ] && return 0
  done
  for rf in "$REALM_RULES_DIR"/*.env; do
    [ -f "$rf" ] || continue
    [ "$rf" = "$_exclude" ] && continue
    # shellcheck disable=SC1090
    _rp="$(. "$rf" 2>/dev/null; printf "%s" "${REALM_LISTEN_PORT:-}")"
    [ "$_rp" = "$_p" ] && return 0
  done
  if command -v ss >/dev/null 2>&1; then
    ss -ltnH 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${_p}\$" && return 0
  elif command -v netstat >/dev/null 2>&1; then
    netstat -ltn 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${_p}\$" && return 0
  fi
  return 1
}

# 询问监听端口并校验（数字 / 范围 / 占用）
# $1 提示  $2 默认值  $3 排除文件
ask_listen_port(){
  _prompt="$1"; _default="$2"; _exclude="${3:-}"
  while true; do
    _p="$(ask "$_prompt" "$_default")"
    case "$_p" in
      ''|*[!0-9]*) red "端口必须是数字。" >&2; _default="$(rand_port)"; continue ;;
    esac
    if [ "$_p" -lt 1 ] || [ "$_p" -gt 65535 ]; then
      red "端口需在 1-65535。" >&2; _default="$(rand_port)"; continue
    fi
    if port_in_use "$_p" "$_exclude"; then
      yellow "端口 $_p 已被占用（其他节点或系统服务），请换一个。" >&2
      _default="$(rand_port)"; continue
    fi
    printf "%s" "$_p"
    return
  done
}

ask_port(){
  _prompt="$1"; _default="$2"
  while true; do
    _p="$(ask "$_prompt" "$_default")"
    case "$_p" in ''|*[!0-9]*) red "端口必须是数字。" >&2; continue ;; esac
    if [ "$_p" -ge 1 ] && [ "$_p" -le 65535 ]; then printf "%s" "$_p"; return; fi
    red "端口需在 1-65535。" >&2
  done
}

node_link(){
  f="$1"; load_node "$f"
  if [ "$NODE_TYPE" = "vless" ]; then
    echo "vless://${UUID}@${PUBLIC_HOST}:${EXT_PORT}?encryption=none&flow=xtls-rprx-vision&security=reality&sni=${SNI}&fp=chrome&pbk=${PUBLIC_KEY}&sid=${SHORT_ID}&type=tcp#$(url_encode "$NODE_NAME")"
  elif [ "$NODE_TYPE" = "ss" ]; then
    b64="$(printf "%s:%s" "$METHOD" "$PASSWORD" | base64 | tr -d '\n')"
    echo "ss://${b64}@${PUBLIC_HOST}:${EXT_PORT}#$(url_encode "$NODE_NAME")"
  elif [ "$NODE_TYPE" = "socks" ]; then
    _name="$(url_encode "$NODE_NAME")"
    _auth=""
    if [ -n "${SOCKS_USER:-}" ]; then
      _auth="$(url_encode "$SOCKS_USER"):$(url_encode "$PASSWORD")@"
    fi
    echo "socks://${_auth}${PUBLIC_HOST}:${EXT_PORT}#${_name}"
    echo "socks5://${_auth}${PUBLIC_HOST}:${EXT_PORT}#${_name}"
  elif [ "$NODE_TYPE" = "hy2" ]; then
    echo "hysteria2://$(url_encode "$PASSWORD")@${PUBLIC_HOST}:${EXT_PORT}/?sni=$(url_encode "$SNI")&insecure=1#$(url_encode "$NODE_NAME")"
  elif [ "$NODE_TYPE" = "tuic" ]; then
    echo "tuic://${UUID}:$(url_encode "$PASSWORD")@${PUBLIC_HOST}:${EXT_PORT}/?sni=$(url_encode "$SNI")&congestion_control=bbr&udp_relay_mode=native&allow_insecure=1#$(url_encode "$NODE_NAME")"
  fi
}


