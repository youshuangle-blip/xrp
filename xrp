generate_realm_config(){
  init_dirs
  files="$(find "$REALM_RULES_DIR" -type f -name '*.env' 2>/dev/null | sort)"
  [ -n "$files" ] || { red "暂无 Realm 转发规则。"; return 1; }
  ensure_python || { red "需要 python3 才能生成 Realm 配置。"; return 1; }
  TMP="$REALM_CONF.tmp"
  python3 - "$REALM_RULES_DIR" > "$TMP" <<'PY'
import glob, os, shlex, sys

rules_dir = sys.argv[1]


def parse_env(path):
    data = {}
    with open(path, encoding="utf-8") as f:
        for raw in f:
            raw = raw.rstrip("\n")
            if not raw or "=" not in raw:
                continue
            key, value = raw.split("=", 1)
            try:
                parts = shlex.split(value, posix=True)
            except ValueError:
                parts = []
            data[key] = parts[0] if parts else ""
    return data


def q(value):
    return '"' + str(value or "").replace("\\", "\\\\").replace('"', '\\"') + '"'


rules = [parse_env(p) for p in sorted(glob.glob(os.path.join(rules_dir, "*.env")))]
rules = [r for r in rules if r.get("REALM_LISTEN_PORT") and r.get("REALM_REMOTE_HOST") and r.get("REALM_REMOTE_PORT")]
if not rules:
    raise SystemExit("no realm rules")

print("[log]")
print('level = "warn"')
print('output = "/var/log/realm.log"')
print("")
print("[network]")
print("no_tcp = false")
print("use_udp = true")
for rule in rules:
    listen = f"{rule.get('REALM_LISTEN_HOST') or '0.0.0.0'}:{rule.get('REALM_LISTEN_PORT')}"
    remote = f"{rule.get('REALM_REMOTE_HOST')}:{rule.get('REALM_REMOTE_PORT')}"
    print("")
    if rule.get("REALM_NAME"):
        print(f"# {rule.get('REALM_NAME')}")
    print("[[endpoints]]")
    print(f"listen = {q(listen)}")
    print(f"remote = {q(remote)}")
PY
  rc=$?
  if [ "$rc" -eq 0 ] && [ -s "$TMP" ]; then
    mv "$TMP" "$REALM_CONF"
    chmod 600 "$REALM_CONF"
    return 0
  fi
  rm -f "$TMP"
  red "生成 Realm 配置失败。"
  return 1
}

