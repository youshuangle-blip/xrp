# 监听端口查重：占用返回 0，未占用返回 1
# $1 = 待检端口   $2 = 需排除的节点文件（编辑现有节点时传自身）
port_in_use(){
  _p="$1"; _exclude="${2:-}"
  for nf in "$NODES_DIR"/*.env; do
    [ -f "$nf" ] || continue
    [ "$nf" = "$_exclude" ] && continue
    _lp="$(. "$nf" 2>/dev/null; printf "%s" "${LISTEN_PORT:-}")"
    [ "$_lp" = "$_p" ] && return 0
  done
  if command -v ss >/dev/null 2>&1; then
    ss -ltnH 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${_p}\$" && return 0
  elif command -v netstat >/dev/null 2>&1; then
    netstat -ltn 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${_p}\$" && return 0
  fi
  return 1
}

# 询问监听端口并校验（数字 / 范围 / 占用）
# $1 提示  $2 默认值  $3 排除文件
ask_listen_port(){
  _prompt="$1"; _default="$2"; _exclude="${3:-}"
  while true; do
    _p="$(ask "$_prompt" "$_default")"
    case "$_p" in
      ''|*[!0-9]*) red "端口必须是数字。" >&2; _default="$(rand_port)"; continue ;;
    esac
    if [ "$_p" -lt 1 ] || [ "$_p" -gt 65535 ]; then
      red "端口需在 1-65535。" >&2; _default="$(rand_port)"; continue
    fi
    if port_in_use "$_p" "$_exclude"; then
      yellow "端口 $_p 已被占用（其他节点或系统服务），请换一个。" >&2
      _default="$(rand_port)"; continue
    fi
    printf "%s" "$_p"
    return
  done
}

node_link(){
  f="$1"; load_node "$f"
  if [ "$NODE_TYPE" = "vless" ]; then
    echo "vless://${UUID}@${PUBLIC_HOST}:${EXT_PORT}?encryption=none&flow=xtls-rprx-vision&security=reality&sni=${SNI}&fp=chrome&pbk=${PUBLIC_KEY}&sid=${SHORT_ID}&type=tcp#$(url_encode "$NODE_NAME")"
  elif [ "$NODE_TYPE" = "ss" ]; then
    b64="$(printf "%s:%s" "$METHOD" "$PASSWORD" | base64 | tr -d '\n')"
    echo "ss://${b64}@${PUBLIC_HOST}:${EXT_PORT}#$(url_encode "$NODE_NAME")"
  else
    echo "SOCKS5 无统一通用导入链接，请使用手动参数。"
  fi
}

clash_yaml(){
  f="$1"; _mode="${2:-proxy}"; load_node "$f"
  command -v python3 >/dev/null 2>&1 || { yellow "需要 python3 才能生成 Clash Meta 配置。"; return 1; }
  python3 - "$_mode" "$NODE_TYPE" "$NODE_NAME" "$PUBLIC_HOST" "$EXT_PORT" "$UUID" "$SNI" "$PUBLIC_KEY" "$SHORT_ID" "$METHOD" "$PASSWORD" "$SOCKS_USER" <<'PY'
import sys

mode, node_type, name, server, port, uuid, sni, public_key, short_id, method, password, socks_user = sys.argv[1:13]


def q(value):
    value = value or ""
    return '"' + value.replace("\\", "\\\\").replace('"', '\\"') + '"'


def proxy_lines(indent="  "):
    if node_type == "vless":
        return [
            f"{indent}- name: {q(name)}",
            f"{indent}  type: vless",
            f"{indent}  server: {q(server)}",
            f"{indent}  port: {port}",
            f"{indent}  uuid: {q(uuid)}",
            f"{indent}  network: tcp",
            f"{indent}  tls: true",
            f"{indent}  udp: true",
            f"{indent}  flow: xtls-rprx-vision",
            f"{indent}  servername: {q(sni)}",
            f"{indent}  client-fingerprint: chrome",
            f"{indent}  reality-opts:",
            f"{indent}    public-key: {q(public_key)}",
            f"{indent}    short-id: {q(short_id)}",
        ]
    if node_type == "ss":
        return [
            f"{indent}- name: {q(name)}",
            f"{indent}  type: ss",
            f"{indent}  server: {q(server)}",
            f"{indent}  port: {port}",
            f"{indent}  cipher: {q(method)}",
            f"{indent}  password: {q(password)}",
            f"{indent}  udp: true",
        ]
    if node_type == "socks":
        lines = [
            f"{indent}- name: {q(name)}",
            f"{indent}  type: socks5",
            f"{indent}  server: {q(server)}",
            f"{indent}  port: {port}",
            f"{indent}  udp: true",
        ]
        if socks_user:
            lines.extend([
                f"{indent}  username: {q(socks_user)}",
                f"{indent}  password: {q(password)}",
            ])
        return lines
    return []


if mode == "config":
    lines = [
        "mixed-port: 7890",
        "allow-lan: false",
        "mode: rule",
        "log-level: info",
        "proxies:",
        *proxy_lines("  "),
        "proxy-groups:",
        "  - name: PROXY",
        "    type: select",
        "    proxies:",
        f"      - {q(name)}",
        "rules:",
        "  - MATCH,PROXY",
    ]
else:
    lines = proxy_lines("  ")

print("\n".join(lines))
PY
}

safe_file_name(){
  _raw="$1"
  _clean="$(printf "%s" "$_raw" | tr -cd 'A-Za-z0-9._-')"
  [ -n "$_clean" ] || _clean="node"
  printf "%s" "$_clean" | cut -c1-32
}

