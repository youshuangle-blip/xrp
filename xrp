select_node_file(){
  init_dirs
  files="$(find "$NODES_DIR" -type f -name '*.env' 2>/dev/null | sort)"
  [ -n "$files" ] || { red "暂无节点。"; return 1; }
  i=1
  for f in $files; do
    load_node "$f"
    echo " [$i] $NODE_NAME | $NODE_TYPE | $PUBLIC_HOST:$EXT_PORT | 监听 $LISTEN_PORT"
    eval "NODE_FILE_$i=\"$f\""
    i=$((i+1))
  done
  printf "\033[32m请选择节点: \033[0m"
  read -r n
  case "$n" in
    ''|*[!0-9]*) red "选择无效。"; return 1 ;;
  esac
  eval "SELECTED_NODE=\${NODE_FILE_$n:-}"
  [ -n "${SELECTED_NODE:-}" ] || { red "选择无效。"; return 1; }
  return 0
}

select_relay_file(){
  init_dirs
  files="$(find "$RELAYS_DIR" -type f -name '*.env' 2>/dev/null | sort)"
  [ -n "$files" ] || { red "暂无中转。"; return 1; }
  i=1
