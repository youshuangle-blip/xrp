generate_hy2_certificate(){
  _id="$1"; _sni="$2"
  CERT_FILE="$CERTS_DIR/${_id}.crt"
  KEY_FILE="$CERTS_DIR/${_id}.key"
  _cfg="/tmp/xrp-openssl-${_id}.cnf"
  cat > "$_cfg" <<EOF
[req]
distinguished_name=req_dn
x509_extensions=v3_req
prompt=no
[req_dn]
CN=$_sni
[v3_req]
subjectAltName=DNS:$_sni
keyUsage=digitalSignature,keyEncipherment
extendedKeyUsage=serverAuth
EOF
  if ! openssl req -x509 -newkey rsa:2048 -nodes -sha256 -days 3650 \
    -config "$_cfg" -keyout "$KEY_FILE" -out "$CERT_FILE" >/dev/null 2>&1; then
    rm -f "$_cfg" "$CERT_FILE" "$KEY_FILE"
    red "生成 Hysteria2 TLS 证书失败。"
    return 1
  fi
  rm -f "$_cfg"
  chmod 600 "$KEY_FILE" "$CERT_FILE"
}


