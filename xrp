#!/bin/sh
# sing-box 节点管理面板 v5.0
# v4.2 变更：config.json 改由 python3 统一生成（消灭手拼 JSON 漏逗号风险，
#           并减少大量子进程）；apply_config_silent 失败时给出提示而非静默；
#           监听端口查重（节点间 + 系统占用）；选择项做数字校验；
#           只缺 python3 时单独安装而非整套重装。
# v4.3 变更：添加中转时支持解析 ss/socks/vless 节点链接；
#           添加中转后可直接新增或绑定入站节点并设置中转策略。
# v4.4 变更：新增面板脚本自更新菜单，从 GitHub 拉取最新版 xrp。
# v4.5 变更：查看/生成节点链接时同时输出 Clash Meta YAML 配置。
# v4.6 变更：新增 Clash 配置文件生成，减少终端 YAML 输出。
# v5.0 变更：核心从 Xray 切换为 sing-box，保留原节点/中转数据。
# v5.1 变更：修复部分系统安装 sing-box 后 PATH 未识别导致无法生成 Reality 密钥。

set -u

CONF_DIR="/usr/local/etc/sing-box"
CONF_FILE="$CONF_DIR/config.json"
DAT_DIR="/usr/local/share/sing-box"
DATA_DIR="/usr/local/etc/xray/xrp"
NODES_DIR="$DATA_DIR/nodes"
RELAYS_DIR="$DATA_DIR/relays"
CLASH_DIR="$DATA_DIR/clash"
PANEL_VER="2026.06.17-v5.1"
PANEL_REPO="youshuangle-blip/xrp"
PANEL_BRANCH="${XRP_BRANCH:-main}"
PANEL_RAW_URL="https://raw.githubusercontent.com/${PANEL_REPO}/${PANEL_BRANCH}/xrp"

red(){ printf "\033[31m%s\033[0m\n" "$*"; }
green(){ printf "\033[32m%s\033[0m\n" "$*"; }
yellow(){ printf "\033[33m%s\033[0m\n" "$*"; }
line(){ printf "\033[32m%s\033[0m\n" "--------------------------------------------------"; }

need_root(){ [ "$(id -u)" -eq 0 ] || { red "请用 root 运行"; exit 1; }; }
init_dirs(){ mkdir -p "$CONF_DIR" "$DAT_DIR" "$DATA_DIR" "$NODES_DIR" "$RELAYS_DIR" "$CLASH_DIR"; }
pause(){ printf "\n按回车继续..."; read -r _; }

ask(){
  _prompt="$1"
  _default="${2:-}"
  if [ -n "$_default" ]; then
    printf "\033[32m%s [%s]: \033[0m" "$_prompt" "$_default" >&2
  else
    printf "\033[32m%s: \033[0m" "$_prompt" >&2
  fi
  read -r _ans
  if [ -z "$_ans" ]; then
    _val="$_default"
    if [ -n "$_default" ]; then
      printf "\033[32m已使用默认值：%s\033[0m\n" "$_val" >&2
    fi
  else
    _val="$_ans"
  fi
  printf "%s" "$_val"
}

ask_required(){
  _prompt="$1"
  _default="${2:-}"
  while true; do
    _val="$(ask "$_prompt" "$_default")"
    if [ -n "$_val" ]; then
      printf "%s" "$_val"
      return
    fi
    red "不能为空，请重新输入。" >&2
    _default=""
  done
}

flush_stdin(){
  while read -r -t 0.05 _junk 2>/dev/null; do :; done || true
}

safe_name(){
  _raw="$1"
  _def="$2"
  case "$_raw" in
    *"cat >"*|*"#!/"*|*"EOF"*|*"XRP"*|*"{"*|*"}"*|*"<"*|*">"*)
      yellow "检测到异常输入，已清理多余粘贴内容。" >&2
      flush_stdin
      _raw="$_def"
      ;;
  esac
  _clean="$(printf "%s" "$_raw" | tr -cd 'A-Za-z0-9._-')"
  [ -n "$_clean" ] || _clean="$_def"
  _clean="$(printf "%s" "$_clean" | cut -c1-32)"
  if [ "$_raw" != "$_clean" ]; then
    yellow "名称已规范为：$_clean" >&2
  fi
  printf "%s" "$_clean"
}

ask_name(){
  _prompt="$1"
  _default="$2"
  _raw="$(ask "$_prompt" "$_default")"
  safe_name "$_raw" "$_default"
}

safe_sni(){
  _raw="$1"
  _def="$2"
  case "$_raw" in
    *"cat >"*|*"#!/"*|*"EOF"*|*"XRP"*|*"{"*|*"}"*|*"<"*|*">"*|*" "*)
      yellow "SNI 输入异常，已恢复默认值。" >&2
      flush_stdin
      _raw="$_def"
      ;;
  esac
  case "$_raw" in
    *.*) printf "%s" "$_raw" ;;
    *) yellow "SNI 格式不像域名，已恢复默认值：$_def" >&2; printf "%s" "$_def" ;;
  esac
}

ask_sni(){
  _prompt="$1"
  _default="$2"
  _raw="$(ask "$_prompt" "$_default")"
  safe_sni "$_raw" "$_default"
}

rand_hex(){
  _n="${1:-16}"
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex "$_n"
  else
    tr -dc 'a-f0-9' < /dev/urandom | head -c $((_n * 2)); echo
  fi
}

rand_port(){
  if command -v od >/dev/null 2>&1; then
    od -An -N2 -tu2 /dev/urandom | awk '{print 10000 + ($1 % 55535)}'
  else
    awk 'BEGIN{srand(); print int(10000 + rand() * 55535)}'
  fi
}

url_encode(){
  python3 - "$1" <<'PY' 2>/dev/null || printf "%s" "$1"
import sys, urllib.parse
print(urllib.parse.quote(sys.argv[1], safe=''))
PY
}

parse_relay_link(){
  _link="$1"
  python3 - "$_link" <<'PY'
import base64
import re
import shlex
import sys
import urllib.parse


def fail(msg):
    print(msg, file=sys.stderr)
    sys.exit(1)


def b64_decode(value):
    value = value.strip()
    value += "=" * ((4 - len(value) % 4) % 4)
    try:
        return base64.urlsafe_b64decode(value.encode()).decode()
    except Exception as exc:
        raise ValueError("base64 解码失败") from exc


def port_of(parsed):
    try:
        return parsed.port
    except ValueError as exc:
        raise ValueError("端口格式无效") from exc


def clean_name(value, fallback):
    value = urllib.parse.unquote(value or "")
    value = re.sub(r"[^A-Za-z0-9._-]", "", value)[:32]
    return value or fallback


def emit(data):
    keys = [
        "LINK_RELAY_TYPE", "LINK_NAME", "LINK_SERVER", "LINK_PORT",
        "LINK_METHOD", "LINK_PASSWORD", "LINK_SOCKS_USER",
        "LINK_UUID", "LINK_SNI", "LINK_PUBLIC_KEY", "LINK_SHORT_ID",
        "LINK_FLOW", "LINK_TRANSPORT", "LINK_SECURITY", "LINK_FINGERPRINT",
        "LINK_WS_HOST", "LINK_WS_PATH", "LINK_SERVICE_NAME", "LINK_ALPN", "LINK_SPIDER_X",
    ]
    for key in keys:
        print(f"{key}={shlex.quote(str(data.get(key, '') or ''))}")


link = sys.argv[1].strip()
parsed = urllib.parse.urlsplit(link)
scheme = parsed.scheme.lower()
if not scheme:
    fail("未识别到链接协议。")

query = urllib.parse.parse_qs(parsed.query, keep_blank_values=True)
query = {k.lower(): (v[-1] if v else "") for k, v in query.items()}


def qget(*names):
    for name in names:
        value = query.get(name.lower())
        if value:
            return value
    return ""


name = clean_name(parsed.fragment, "")

try:
    if scheme == "ss":
        host = parsed.hostname or ""
        port = port_of(parsed)
        userinfo = ""
        method = ""
        password = ""
        if host and port and "@" in parsed.netloc:
            userinfo = urllib.parse.unquote(parsed.netloc.rsplit("@", 1)[0])
            if ":" in userinfo:
                method, password = userinfo.split(":", 1)
            else:
                method, password = b64_decode(userinfo).split(":", 1)
        else:
            token = (parsed.netloc + parsed.path).lstrip("/")
            decoded = b64_decode(token)
            if "@" not in decoded:
                fail("SS 链接缺少服务器地址。")
            auth, endpoint = decoded.rsplit("@", 1)
            if ":" not in auth:
                fail("SS 链接缺少加密方式或密码。")
            method, password = auth.split(":", 1)
            endpoint_parsed = urllib.parse.urlsplit("//" + endpoint)
            host = endpoint_parsed.hostname or ""
            port = port_of(endpoint_parsed)
        if not host or not port or not method:
            fail("SS 链接参数不完整。")
        emit({
            "LINK_RELAY_TYPE": "ss",
            "LINK_NAME": name,
            "LINK_SERVER": host,
            "LINK_PORT": port,
            "LINK_METHOD": urllib.parse.unquote(method),
            "LINK_PASSWORD": urllib.parse.unquote(password),
        })
    elif scheme in ("socks", "socks5", "socks5h"):
        host = parsed.hostname or ""
        port = port_of(parsed)
        if not host or not port:
            fail("SOCKS 链接缺少地址或端口。")
        emit({
            "LINK_RELAY_TYPE": "socks",
            "LINK_NAME": name,
            "LINK_SERVER": host,
            "LINK_PORT": port,
            "LINK_SOCKS_USER": urllib.parse.unquote(parsed.username or ""),
            "LINK_PASSWORD": urllib.parse.unquote(parsed.password or ""),
        })
    elif scheme == "vless":
        host = parsed.hostname or ""
        port = port_of(parsed)
        uuid = urllib.parse.unquote(parsed.username or "")
        if not host or not port or not uuid:
            fail("VLESS 链接缺少 UUID、地址或端口。")
        emit({
            "LINK_RELAY_TYPE": "vless",
            "LINK_NAME": name,
            "LINK_SERVER": host,
            "LINK_PORT": port,
            "LINK_UUID": uuid,
            "LINK_SNI": qget("sni", "servername", "peer"),
            "LINK_PUBLIC_KEY": qget("pbk", "publickey"),
            "LINK_SHORT_ID": qget("sid", "shortid"),
            "LINK_FLOW": qget("flow"),
            "LINK_TRANSPORT": qget("type") or "tcp",
            "LINK_SECURITY": qget("security") or "none",
            "LINK_FINGERPRINT": qget("fp", "fingerprint"),
            "LINK_WS_HOST": qget("host"),
            "LINK_WS_PATH": qget("path"),
            "LINK_SERVICE_NAME": qget("servicename"),
            "LINK_ALPN": qget("alpn"),
            "LINK_SPIDER_X": qget("spx", "spiderx"),
        })
    else:
        fail("暂不支持该链接协议：%s。当前支持 ss://、socks://、socks5://、vless://。" % scheme)
except ValueError as exc:
    fail(str(exc))
PY
}

shell_quote(){
  printf "%s" "$1" | sed "s/'/'\\\\''/g; 1s/^/'/; \$s/\$/'/"
}

detect_init(){
  if command -v systemctl >/dev/null 2>&1 && [ -d /run/systemd/system ]; then
    echo "systemd"
  elif command -v rc-service >/dev/null 2>&1; then
    echo "openrc"
  else
    echo "unknown"
  fi
}

system_name(){
  if [ -f /etc/alpine-release ]; then
    echo "Alpine Linux v$(cat /etc/alpine-release)"
  elif [ -f /etc/os-release ]; then
    . /etc/os-release
    echo "${PRETTY_NAME:-Linux}"
  else
    uname -s
  fi
}

service_running(){
  INIT="$(detect_init)"
  if [ "$INIT" = "systemd" ]; then
    systemctl is-active --quiet sing-box && echo "已运行" || echo "已停止"
  elif [ "$INIT" = "openrc" ]; then
    rc-service sing-box status 2>/dev/null | grep -q started && echo "已运行" || echo "已停止"
  else
    pgrep sing-box >/dev/null 2>&1 && echo "已运行" || echo "已停止"
  fi
}

count_files(){ find "$1" -type f -name '*.env' 2>/dev/null | wc -l | tr -d ' '; }
singbox_bin(){
  if command -v sing-box >/dev/null 2>&1; then
    command -v sing-box
    return 0
  fi
  if [ -x /usr/local/bin/sing-box ]; then
    printf "%s\n" /usr/local/bin/sing-box
    return 0
  fi
  return 1
}
core_ver(){ _bin="$(singbox_bin 2>/dev/null)" && "$_bin" version | head -n1 || echo "未安装"; }

get_public_ip(){
  for u in "https://api.ipify.org" "https://ipv4.icanhazip.com" "https://ifconfig.me/ip"; do
    ip="$(curl -4 -fsS --max-time 2 "$u" 2>/dev/null | tr -d '\r\n ' || true)"
    case "$ip" in *.*.*.*) echo "$ip"; return ;; esac
  done
  hostname -I 2>/dev/null | awk '{print $1}'
}

gen_uuid(){
  _bin="$(singbox_bin 2>/dev/null || echo /usr/local/bin/sing-box)"
  if [ -x "$_bin" ]; then "$_bin" generate uuid 2>/dev/null && return; fi
  if [ -r /proc/sys/kernel/random/uuid ]; then cat /proc/sys/kernel/random/uuid; else printf "%s-%s-%s-%s-%s\n" "$(rand_hex 4)" "$(rand_hex 2)" "$(rand_hex 2)" "$(rand_hex 2)" "$(rand_hex 6)"; fi
}

gen_x25519(){
  _bin="$(singbox_bin 2>/dev/null || echo /usr/local/bin/sing-box)"
  [ -x "$_bin" ] || return 1
  KEYPAIR="$("$_bin" generate reality-keypair 2>/dev/null || true)"
  PRIVATE_KEY="$(printf "%s\n" "$KEYPAIR" | sed -n 's/^PrivateKey:[[:space:]]*//p; s/^Private key:[[:space:]]*//p' | head -n1)"
  PUBLIC_KEY="$(printf "%s\n" "$KEYPAIR" | sed -n 's/^PublicKey:[[:space:]]*//p; s/^Public key:[[:space:]]*//p; s/^Password (PublicKey):[[:space:]]*//p' | head -n1)"
  [ -n "$PRIVATE_KEY" ] && [ -n "$PUBLIC_KEY" ]
}

ensure_python(){
  command -v python3 >/dev/null 2>&1 && return 0
  yellow "正在安装 python3..." >&2
  if command -v apk >/dev/null 2>&1; then
    apk add --no-cache python3 >/dev/null
  elif command -v apt-get >/dev/null 2>&1; then
    apt-get update >/dev/null && DEBIAN_FRONTEND=noninteractive apt-get install -y python3 >/dev/null
  elif command -v dnf >/dev/null 2>&1; then
    dnf install -y python3 >/dev/null
  elif command -v yum >/dev/null 2>&1; then
    yum install -y python3 >/dev/null
  fi
  command -v python3 >/dev/null 2>&1
}

reset_node_vars(){
  NODE_ID=""; NODE_TAG=""; NODE_TYPE=""; NODE_NAME=""; PUBLIC_HOST=""; LISTEN_PORT=""; EXT_PORT=""
  SNI=""; UUID=""; PRIVATE_KEY=""; PUBLIC_KEY=""; SHORT_ID=""; METHOD=""; PASSWORD=""; SOCKS_USER=""
  NODE_RELAY_MODE="direct"; NODE_RELAY_TAG=""
}

reset_relay_vars(){
  RELAY_ID=""; RELAY_TAG=""; RELAY_TYPE=""; RELAY_NAME=""; SERVER=""; PORT=""; METHOD=""; PASSWORD=""; SOCKS_USER=""
  UUID=""; SNI=""; PUBLIC_KEY=""; SHORT_ID=""; FLOW=""; TRANSPORT=""; SECURITY=""; FINGERPRINT=""; WS_HOST=""; WS_PATH=""; SERVICE_NAME=""; ALPN=""; SPIDER_X=""
}

load_node(){ reset_node_vars; . "$1"; }
load_relay(){ reset_relay_vars; . "$1"; }

install_deps(){
  if command -v apk >/dev/null 2>&1; then
    apk add --no-cache curl wget unzip tar ca-certificates openssl python3 coreutils >/dev/null
  elif command -v apt-get >/dev/null 2>&1; then
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y curl wget unzip tar ca-certificates openssl python3
  elif command -v dnf >/dev/null 2>&1; then
    dnf install -y curl wget unzip tar ca-certificates openssl python3
  elif command -v yum >/dev/null 2>&1; then
    yum install -y curl wget unzip tar ca-certificates openssl python3
  else
    yellow "未识别包管理器，请手动保证 curl/wget/unzip/tar/openssl/python3 可用"
  fi
}

arch_name(){
  case "$(uname -m)" in
    x86_64|amd64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    armv7l|armv7) echo "armv7" ;;
    armv6l) echo "armv6" ;;
    i386|i686) echo "386" ;;
    *) red "暂不支持架构：$(uname -m)"; exit 1 ;;
  esac
}

install_singbox(){
  need_root; init_dirs; install_deps
  ARCH="$(arch_name)"
  TMP="/tmp/sing-box-install"
  rm -rf "$TMP"; mkdir -p "$TMP"
  yellow "正在获取 sing-box 最新版本..."
  API="$(curl -fsSL --connect-timeout 12 --max-time 20 --retry 2 https://api.github.com/repos/SagerNet/sing-box/releases/latest 2>/dev/null || true)"
  VER="$(printf "%s\n" "$API" | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p' | head -n1)"
  [ -n "$VER" ] || { red "获取版本失败，检查服务器网络能否访问 GitHub。"; return 1; }
  URL="https://github.com/SagerNet/sing-box/releases/download/v${VER}/sing-box-${VER}-linux-${ARCH}.tar.gz"
  yellow "下载：$URL"
  curl -fL --connect-timeout 20 --max-time 120 --retry 2 "$URL" -o "$TMP/sing-box.tar.gz" || { red "下载失败。"; return 1; }
  tar -xzf "$TMP/sing-box.tar.gz" -C "$TMP" || { red "解压失败。"; return 1; }
  BIN="$(find "$TMP" -type f -name sing-box | head -n1)"
  [ -n "$BIN" ] || { red "解压后未找到 sing-box。"; return 1; }
  mkdir -p /usr/local/bin
  if command -v install >/dev/null 2>&1; then
    install -m 755 "$BIN" /usr/local/bin/sing-box || { red "安装 sing-box 到 /usr/local/bin 失败。"; return 1; }
  else
    cp "$BIN" /usr/local/bin/sing-box && chmod 755 /usr/local/bin/sing-box || { red "安装 sing-box 到 /usr/local/bin 失败。"; return 1; }
  fi
  hash -r 2>/dev/null || true
  [ -x /usr/local/bin/sing-box ] || { red "/usr/local/bin/sing-box 不存在或不可执行。"; return 1; }
  /usr/local/bin/sing-box version >/dev/null 2>&1 || {
    red "sing-box 已下载但无法运行。可能是系统架构不匹配或二进制不兼容。"
    red "请执行：ls -l /usr/local/bin/sing-box && /usr/local/bin/sing-box version"
    return 1
  }
  stop_legacy_xray
  install_service
  green "sing-box 核心安装/更新完成"
  /usr/local/bin/sing-box version | head -n1
}

install_service(){
  INIT="$(detect_init)"
  CORE_BIN="$(singbox_bin 2>/dev/null || echo /usr/local/bin/sing-box)"
  if [ "$INIT" = "systemd" ]; then
    cat > /etc/systemd/system/sing-box.service <<EOF
[Unit]
Description=sing-box Service
After=network.target nss-lookup.target

[Service]
User=root
ExecStart=$CORE_BIN run -c $CONF_FILE
Restart=always
RestartSec=3
LimitNOFILE=infinity

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable sing-box >/dev/null 2>&1 || true
  elif [ "$INIT" = "openrc" ]; then
    cat > /etc/init.d/sing-box <<EOF
#!/sbin/openrc-run

name="sing-box"
description="sing-box Service"
command="$CORE_BIN"
command_args="run -c $CONF_FILE"
command_background=true
pidfile="/run/sing-box.pid"
output_log="/var/log/sing-box.log"
error_log="/var/log/sing-box.err"

depend() {
    need net
    after firewall
}
EOF
    chmod +x /etc/init.d/sing-box
    rc-update add sing-box default >/dev/null 2>&1 || true
  else
    yellow "未识别服务管理器，需手动运行：$CORE_BIN run -c $CONF_FILE"
  fi
}

svc_start(){
  INIT="$(detect_init)"
  if [ "$INIT" = "systemd" ]; then systemctl restart sing-box; systemctl status sing-box --no-pager -l
  elif [ "$INIT" = "openrc" ]; then rc-service sing-box restart; rc-service sing-box status
  else _bin="$(singbox_bin 2>/dev/null || echo sing-box)"; "$_bin" run -c "$CONF_FILE"; fi
}

svc_stop(){
  INIT="$(detect_init)"
  if [ "$INIT" = "systemd" ]; then systemctl stop sing-box
  elif [ "$INIT" = "openrc" ]; then rc-service sing-box stop
  else pkill sing-box 2>/dev/null || true; fi
}

svc_status(){
  INIT="$(detect_init)"
  if [ "$INIT" = "systemd" ]; then systemctl status sing-box --no-pager -l
  elif [ "$INIT" = "openrc" ]; then rc-service sing-box status; tail -n 30 /var/log/sing-box.err 2>/dev/null || true
  else ps | grep sing-box | grep -v grep || true; fi
}

svc_logs(){
  INIT="$(detect_init)"
  if [ "$INIT" = "systemd" ]; then journalctl -u sing-box --no-pager -n 100
  elif [ "$INIT" = "openrc" ]; then echo "== /var/log/sing-box.log =="; tail -n 100 /var/log/sing-box.log 2>/dev/null || true; echo "== /var/log/sing-box.err =="; tail -n 100 /var/log/sing-box.err 2>/dev/null || true
  else red "未识别日志位置。"; fi
}

stop_legacy_xray(){
  INIT="$(detect_init)"
  if [ "$INIT" = "systemd" ]; then
    systemctl stop xray >/dev/null 2>&1 || true
    systemctl disable xray >/dev/null 2>&1 || true
  elif [ "$INIT" = "openrc" ]; then
    rc-service xray stop >/dev/null 2>&1 || true
    rc-update del xray default >/dev/null 2>&1 || true
  else
    pkill xray >/dev/null 2>&1 || true
  fi
}

write_node(){
  FILE="$NODES_DIR/$NODE_ID.env"
  {
    printf "NODE_ID=%s\n" "$(shell_quote "$NODE_ID")"
    printf "NODE_TAG=%s\n" "$(shell_quote "$NODE_TAG")"
    printf "NODE_TYPE=%s\n" "$(shell_quote "$NODE_TYPE")"
    printf "NODE_NAME=%s\n" "$(shell_quote "$NODE_NAME")"
    printf "PUBLIC_HOST=%s\n" "$(shell_quote "$PUBLIC_HOST")"
    printf "LISTEN_PORT=%s\n" "$(shell_quote "$LISTEN_PORT")"
    printf "EXT_PORT=%s\n" "$(shell_quote "$EXT_PORT")"
    printf "SNI=%s\n" "$(shell_quote "${SNI:-}")"
    printf "UUID=%s\n" "$(shell_quote "${UUID:-}")"
    printf "PRIVATE_KEY=%s\n" "$(shell_quote "${PRIVATE_KEY:-}")"
    printf "PUBLIC_KEY=%s\n" "$(shell_quote "${PUBLIC_KEY:-}")"
    printf "SHORT_ID=%s\n" "$(shell_quote "${SHORT_ID:-}")"
    printf "METHOD=%s\n" "$(shell_quote "${METHOD:-}")"
    printf "PASSWORD=%s\n" "$(shell_quote "${PASSWORD:-}")"
    printf "SOCKS_USER=%s\n" "$(shell_quote "${SOCKS_USER:-}")"
    printf "NODE_RELAY_MODE=%s\n" "$(shell_quote "${NODE_RELAY_MODE:-direct}")"
    printf "NODE_RELAY_TAG=%s\n" "$(shell_quote "${NODE_RELAY_TAG:-}")"
  } > "$FILE"
  chmod 600 "$FILE"
}

write_relay(){
  FILE="$RELAYS_DIR/$RELAY_ID.env"
