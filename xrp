# 从节点和核心中转任务统一生成 Xray / sing-box 配置。
generate_core_config(){
  _core="$1"; _output="$2"
  ensure_python || { red "需要 python3 生成配置。"; return 1; }
  python3 - "$_core" "$NODES_DIR" "$CORE_ROUTES_DIR" > "$_output" <<'PY'
import glob
import json
import os
import shlex
import sys

core, nodes_dir, routes_dir = sys.argv[1:4]


def parse_env(path):
    data = {}
    with open(path, encoding="utf-8") as f:
        for raw in f:
            raw = raw.rstrip("\n")
            if not raw or "=" not in raw:
                continue
            key, value = raw.split("=", 1)
            try:
                parts = shlex.split(value, posix=True)
            except ValueError:
                parts = []
            data[key] = parts[0] if parts else ""
    return data


def load_dir(path):
    return [parse_env(p) for p in sorted(glob.glob(os.path.join(path, "*.env")))]


def number(value):
    try:
        return int(value)
    except (TypeError, ValueError):
        return 0


def xray_inbound(node):
    kind = node.get("NODE_TYPE")
    inbound = {
        "tag": node.get("NODE_TAG"), "listen": "0.0.0.0",
        "port": number(node.get("LISTEN_PORT")),
        "sniffing": {"enabled": True, "destOverride": ["http", "tls", "quic"]},
    }
    if kind == "vless":
        sni = node.get("SNI")
        inbound.update(
            protocol="vless",
            settings={"clients": [{"id": node.get("UUID"), "flow": "xtls-rprx-vision", "email": node.get("NODE_NAME")}], "decryption": "none"},
            streamSettings={"network": "tcp", "security": "reality", "realitySettings": {
                "show": False, "dest": f"{sni}:443", "xver": 0, "serverNames": [sni],
                "privateKey": node.get("PRIVATE_KEY"), "shortIds": [node.get("SHORT_ID")],
            }},
        )
    elif kind == "ss":
        inbound.update(protocol="shadowsocks", settings={
            "method": node.get("METHOD"), "password": node.get("PASSWORD"), "network": "tcp,udp",
        })
    elif kind == "socks":
        user = node.get("SOCKS_USER")
        settings = {"auth": "noauth", "udp": True, "ip": "0.0.0.0"}
        if user:
            settings.update(auth="password", accounts=[{"user": user, "pass": node.get("PASSWORD")}])
        inbound.update(protocol="socks", settings=settings)
    else:
        return None
    return inbound


def xray_outbound(route):
    kind, tag = route.get("OUT_TYPE"), "route_out_" + route.get("ROUTE_ID", "")
    host, port = route.get("OUT_HOST"), number(route.get("OUT_PORT"))
    if kind == "vless":
        user = {"id": route.get("OUT_UUID"), "encryption": "none"}
        if route.get("OUT_FLOW"):
            user["flow"] = route.get("OUT_FLOW")
        outbound = {"protocol": "vless", "tag": tag, "settings": {"vnext": [{"address": host, "port": port, "users": [user]}]}}
        security = route.get("OUT_SECURITY") or "none"
        stream = {"network": "tcp", "security": security}
        if security == "reality":
            stream["realitySettings"] = {
                "serverName": route.get("OUT_SNI"), "fingerprint": route.get("OUT_FP") or "chrome",
                "publicKey": route.get("OUT_PBK"), "shortId": route.get("OUT_SID"), "spiderX": "",
            }
        elif security == "tls":
            stream["tlsSettings"] = {"serverName": route.get("OUT_SNI"), "fingerprint": route.get("OUT_FP") or "chrome"}
        outbound["streamSettings"] = stream
        return outbound
    if kind == "ss":
        return {"protocol": "shadowsocks", "tag": tag, "settings": {"servers": [{
            "address": host, "port": port, "method": route.get("OUT_METHOD"), "password": route.get("OUT_PASSWORD"),
        }]}}
    if kind == "socks":
        server = {"address": host, "port": port}
        if route.get("OUT_USER"):
            server["users"] = [{"user": route.get("OUT_USER"), "pass": route.get("OUT_PASSWORD")}]
        return {"protocol": "socks", "tag": tag, "settings": {"servers": [server]}}
    return None


def sing_inbound(node):
    kind = node.get("NODE_TYPE")
    if kind == "hy2":
        return {
            "type": "hysteria2", "tag": node.get("NODE_TAG"), "listen": "0.0.0.0",
            "listen_port": number(node.get("LISTEN_PORT")),
            "users": [{"name": node.get("NODE_NAME"), "password": node.get("PASSWORD")}],
            "tls": {"enabled": True, "server_name": node.get("SNI"),
                    "certificate_path": node.get("CERT_FILE"), "key_path": node.get("KEY_FILE")},
        }
    if kind == "tuic":
        return {
            "type": "tuic", "tag": node.get("NODE_TAG"), "listen": "0.0.0.0",
            "listen_port": number(node.get("LISTEN_PORT")),
            "users": [{"uuid": node.get("UUID"), "password": node.get("PASSWORD")}],
            "congestion_control": "bbr",
            "tls": {"enabled": True, "server_name": node.get("SNI"),
                    "certificate_path": node.get("CERT_FILE"), "key_path": node.get("KEY_FILE")},
        }
    return None


def sing_outbound(route):
    kind, tag = route.get("OUT_TYPE"), "route_out_" + route.get("ROUTE_ID", "")
    base = {"type": kind, "tag": tag, "server": route.get("OUT_HOST"), "server_port": number(route.get("OUT_PORT"))}
    if kind == "vless":
        base.update(uuid=route.get("OUT_UUID"), flow=route.get("OUT_FLOW"))
        security = route.get("OUT_SECURITY") or "none"
        if security in ("tls", "reality"):
            tls = {"enabled": True, "server_name": route.get("OUT_SNI")}
            if security == "reality":
                tls["reality"] = {"enabled": True, "public_key": route.get("OUT_PBK"), "short_id": route.get("OUT_SID")}
            base["tls"] = tls
        return base
    if kind == "ss":
        base["type"] = "shadowsocks"
        base.update(method=route.get("OUT_METHOD"), password=route.get("OUT_PASSWORD"))
        return base
    if kind == "socks":
        base.update(version="5")
        if route.get("OUT_USER"):
            base.update(username=route.get("OUT_USER"), password=route.get("OUT_PASSWORD"))
        return base
    if kind == "hy2":
        base["type"] = "hysteria2"
        base["password"] = route.get("OUT_PASSWORD")
        base["tls"] = {"enabled": True, "server_name": route.get("OUT_SNI"),
                       "insecure": route.get("OUT_INSECURE") == "true"}
        if route.get("OUT_OBFS"):
            base["obfs"] = {"type": route.get("OUT_OBFS"), "password": route.get("OUT_OBFS_PASSWORD")}
        return base
    if kind == "tuic":
        base.update(uuid=route.get("OUT_UUID"), password=route.get("OUT_PASSWORD"),
                    congestion_control="bbr", udp_relay_mode="native")
        base["tls"] = {"enabled": True, "server_name": route.get("OUT_SNI"),
                       "insecure": route.get("OUT_INSECURE") == "true"}
        return base
    return None


nodes, routes = load_dir(nodes_dir), load_dir(routes_dir)
if core == "xray":
    inbounds = [item for item in (xray_inbound(n) for n in nodes + routes) if item]
    if not inbounds:
        raise SystemExit(3)
    outbounds = [{"protocol": "freedom", "tag": "direct", "settings": {}}]
    rules = []
    for route in routes:
        if route.get("NODE_TYPE") in ("hy2", "tuic"):
            continue
        outbound = xray_outbound(route)
        if outbound:
            outbounds.append(outbound)
            rules.append({"type": "field", "inboundTag": [route.get("NODE_TAG")], "outboundTag": outbound["tag"]})
    config = {"log": {"loglevel": "warning"}, "inbounds": inbounds, "outbounds": outbounds,
              "routing": {"domainStrategy": "AsIs", "rules": rules}}
elif core == "sing-box":
    inbounds = [item for item in (sing_inbound(n) for n in nodes + routes) if item]
    if not inbounds:
        raise SystemExit(3)
    outbounds = [{"type": "direct", "tag": "direct"}]
    rules = []
    for route in routes:
        if route.get("NODE_TYPE") not in ("hy2", "tuic"):
            continue
        outbound = sing_outbound(route)
        if outbound:
            outbounds.append(outbound)
            rules.append({"inbound": [route.get("NODE_TAG")], "action": "route", "outbound": outbound["tag"]})
    config = {"log": {"level": "warn", "timestamp": True}, "inbounds": inbounds,
              "outbounds": outbounds, "route": {"rules": rules, "final": "direct"}}
else:
    raise SystemExit(2)

json.dump(config, sys.stdout, ensure_ascii=False, indent=2)
sys.stdout.write("\n")
PY
}

stop_core_service(){
  _core="$1"; INIT="$(detect_init)"
  if [ "$INIT" = "systemd" ]; then
    systemctl stop "$_core" >/dev/null 2>&1 || true
    systemctl disable "$_core" >/dev/null 2>&1 || true
  elif [ "$INIT" = "openrc" ]; then
    rc-service "$_core" stop >/dev/null 2>&1 || true
    rc-update del "$_core" default >/dev/null 2>&1 || true
  else pkill "$_core" >/dev/null 2>&1 || true; fi
}

restart_core_service(){
  _core="$1"; INIT="$(detect_init)"
  if [ "$_core" = "xray" ]; then install_service >/dev/null 2>&1
  else install_singbox_service >/dev/null 2>&1; fi
  if [ "$INIT" = "systemd" ]; then systemctl restart "$_core" >/dev/null 2>&1
  elif [ "$INIT" = "openrc" ]; then rc-service "$_core" restart >/dev/null 2>&1
  else return 0; fi
}

apply_core_config(){
  _core="$1"
  if [ "$_core" = "xray" ]; then _target="$CONF_FILE"; _binary="xray"
  else _target="$SINGBOX_CONF"; _binary="sing-box"; fi
  command -v "$_binary" >/dev/null 2>&1 || return 0
  _tmp="${_target}.new.$$"
  generate_core_config "$_core" "$_tmp"
  _rc=$?
  if [ "$_rc" -eq 3 ]; then
    rm -f "$_tmp" "$_target"
    stop_core_service "$_core"
    return 0
  fi
  if [ "$_rc" -ne 0 ] || [ ! -s "$_tmp" ]; then
    rm -f "$_tmp"; red "$_core 配置生成失败。"; return 1
  fi
  if [ "$_core" = "xray" ]; then
    xray run -test -config "$_tmp" >/dev/null 2>&1 || { xray run -test -config "$_tmp"; rm -f "$_tmp"; return 1; }
  else
    sing-box check -c "$_tmp" >/dev/null 2>&1 || { sing-box check -c "$_tmp"; rm -f "$_tmp"; return 1; }
  fi
  _backup="${_target}.bak"
  [ ! -f "$_target" ] || cp -p "$_target" "$_backup"
  mv "$_tmp" "$_target"; chmod 600 "$_target"
  if ! restart_core_service "$_core"; then
    if [ -f "$_backup" ]; then mv "$_backup" "$_target"; restart_core_service "$_core" >/dev/null 2>&1 || true; fi
    red "$_core 重启失败，已尝试恢复上一个配置。"
    return 1
  fi
  rm -f "$_backup"
}

apply_all_configs_silent(){
  _result=0
  apply_core_config xray || _result=1
  apply_core_config sing-box || _result=1
  return "$_result"
}

apply_core_for_type(){
  if [ "$1" = "hy2" ] || [ "$1" = "tuic" ]; then apply_core_config sing-box
  else apply_core_config xray; fi
}

update_panel(){
  need_root
  TMP="/tmp/xrp-panel-update.$$"
  TARGET="$(command -v xrp 2>/dev/null || true)"
  [ -n "$TARGET" ] || TARGET="/usr/local/bin/xrp"
  CACHE_BUST="$(date +%s 2>/dev/null || echo $$)"
  DOWNLOAD_URL="${PANEL_RAW_URL}?v=${CACHE_BUST}"
  yellow "当前版本：$PANEL_VER"
  yellow "正在从 GitHub 下载最新版面板..."
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -H "Cache-Control: no-cache" "$DOWNLOAD_URL" -o "$TMP" || { rm -f "$TMP"; red "下载失败：$DOWNLOAD_URL"; return 1; }
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$TMP" "$DOWNLOAD_URL" || { rm -f "$TMP"; red "下载失败：$DOWNLOAD_URL"; return 1; }
  else
    red "需要 curl 或 wget 才能更新面板。"
    return 1
  fi
  if [ ! -s "$TMP" ] || ! head -n1 "$TMP" | grep -q "^#!/bin/sh"; then
    rm -f "$TMP"
    red "下载内容异常，已取消更新。"
    return 1
  fi
  NEW_VER="$(grep '^PANEL_VER=' "$TMP" | head -n1 | cut -d= -f2- | tr -d '"')"
  [ -n "$NEW_VER" ] && yellow "下载版本：$NEW_VER"
  install -m 755 "$TMP" "$TARGET" || { rm -f "$TMP"; red "安装更新失败：$TARGET"; return 1; }
  rm -f "$TMP"
  green "面板已更新：$TARGET"
  yellow "正在重启并进入新版面板..."
  exec "$TARGET"
}

uninstall_panel(){
  echo " [1] 仅删除面板"
  echo " [2] 删除面板 + Xray + sing-box + Realm + 所有配置"
  printf "\033[32m请选择: \033[0m"
  read -r U
  if [ "$U" = "1" ]; then
    rm -f /usr/local/bin/xrp
    green "已删除面板。"
  elif [ "$U" = "2" ]; then
    printf "确认全部删除？输入 yes: "
    read -r C
    [ "$C" = "yes" ] || { yellow "已取消"; return; }
    svc_stop >/dev/null 2>&1 || true
    realm_stop >/dev/null 2>&1 || true
    INIT="$(detect_init)"
    if [ "$INIT" = "systemd" ]; then
      systemctl disable xray sing-box realm >/dev/null 2>&1 || true
      rm -f /etc/systemd/system/xray.service /etc/systemd/system/sing-box.service /etc/systemd/system/realm.service
      systemctl daemon-reload 2>/dev/null || true
    elif [ "$INIT" = "openrc" ]; then
      rc-update del xray default >/dev/null 2>&1 || true
      rc-update del sing-box default >/dev/null 2>&1 || true
      rc-update del realm default >/dev/null 2>&1 || true
      rm -f /etc/init.d/xray /etc/init.d/sing-box /etc/init.d/realm
    fi
    rm -f /usr/local/bin/xray /usr/local/bin/sing-box /usr/local/bin/realm /usr/local/bin/xrp
    rm -rf "$CONF_DIR" "$SINGBOX_CONF_DIR" "$DAT_DIR"
    rm -f /var/log/xray.log /var/log/xray.err /var/log/sing-box.log /var/log/sing-box.err /var/log/realm.log /var/log/realm.err
    green "已删除面板、全部核心和配置。"
  else
    yellow "已取消。"
  fi
}

