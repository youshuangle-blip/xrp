parse_proxy_link(){
  _link="$1"; _out="$2"
  [ "${#_link}" -le 4096 ] || { red "代理链接过长。"; return 1; }
  python3 - "$_link" "$_out" <<'PY'
import base64
import re
import shlex
import sys
from urllib.parse import parse_qs, unquote, urlsplit

raw, output = sys.argv[1:3]


def fail(message):
    print(message, file=sys.stderr)
    raise SystemExit(1)


def b64decode(value):
    value = value.strip().replace("-", "+").replace("_", "/")
    value += "=" * (-len(value) % 4)
    try:
        return base64.b64decode(value).decode("utf-8")
    except Exception:
        fail("Base64 内容无效")


def valid_host(value):
    if not value or len(value) > 253 or any(c.isspace() for c in value):
        return False
    return bool(re.fullmatch(r"[0-9A-Za-z._:-]+", value))


def split_url(value):
    try:
        parsed = urlsplit(value)
        port = parsed.port
    except ValueError as exc:
        fail(f"链接地址无效：{exc}")
    if not valid_host(parsed.hostname) or not port or not 1 <= port <= 65535:
        fail("链接缺少有效的服务器地址或端口")
    return parsed, port


clean = raw.strip()
initial = urlsplit(clean)
scheme = initial.scheme.lower()
legacy_ss_auth = ""
if scheme == "ss" and "@" not in initial.netloc:
    decoded = b64decode(initial.netloc + initial.path)
    if "@" not in decoded or ":" not in decoded.split("@", 1)[0]:
        fail("Shadowsocks 链接格式无效")
    legacy_ss_auth, endpoint = decoded.rsplit("@", 1)
    u, port = split_url("ss://x@" + endpoint)
else:
    u, port = split_url(clean)
q = {k: values[-1] for k, values in parse_qs(u.query, keep_blank_values=True).items()}
data = {
    "OUT_TYPE": "", "OUT_HOST": u.hostname or "", "OUT_PORT": str(port),
    "OUT_NAME": unquote(initial.fragment) or "imported-proxy", "OUT_UUID": "", "OUT_FLOW": "",
    "OUT_SECURITY": "", "OUT_SNI": "", "OUT_FP": "", "OUT_PBK": "", "OUT_SID": "",
    "OUT_METHOD": "", "OUT_PASSWORD": "", "OUT_USER": "", "OUT_INSECURE": "false",
    "OUT_OBFS": "", "OUT_OBFS_PASSWORD": "",
}

if scheme == "vless":
    data.update(
        OUT_TYPE="vless",
        OUT_UUID=unquote(u.username or ""),
        OUT_FLOW=q.get("flow", ""),
        OUT_SECURITY=q.get("security", "none").lower(),
        OUT_SNI=q.get("sni", q.get("serverName", "")),
        OUT_FP=q.get("fp", "chrome"),
        OUT_PBK=q.get("pbk", ""),
        OUT_SID=q.get("sid", ""),
    )
    if not data["OUT_UUID"]:
        fail("VLESS 链接缺少 UUID")
    if q.get("type", "tcp") not in ("tcp", "raw"):
        fail("当前仅支持 TCP/raw 的 VLESS 出口链接")
    if data["OUT_SECURITY"] not in ("none", "tls", "reality"):
        fail("不支持此 VLESS security 参数")
    if data["OUT_SECURITY"] == "reality" and (not data["OUT_SNI"] or not data["OUT_PBK"]):
        fail("Reality 链接缺少 SNI 或公钥")
elif scheme == "ss":
    data["OUT_TYPE"] = "ss"
    userinfo = clean.split("//", 1)[1].split("@", 1)[0] if "@" in clean else ""
    if legacy_ss_auth:
        method, password = legacy_ss_auth.split(":", 1)
    elif userinfo:
        decoded = unquote(userinfo)
        if ":" not in decoded:
            decoded = b64decode(decoded)
        method, password = decoded.split(":", 1)
    else:
        fail("Shadowsocks 链接格式无效")
    if not method or not password:
        fail("Shadowsocks 链接缺少加密方式或密码")
    data.update(OUT_METHOD=method, OUT_PASSWORD=password)
elif scheme in ("socks", "socks5"):
    data.update(
        OUT_TYPE="socks",
        OUT_USER=unquote(u.username or ""),
        OUT_PASSWORD=unquote(u.password or ""),
    )
elif scheme in ("hysteria2", "hy2"):
    auth = unquote(u.username or "")
    if u.password is not None:
        auth += ":" + unquote(u.password)
    if not auth:
        fail("Hysteria2 链接缺少认证密码")
    insecure = q.get("insecure", "0").lower() in ("1", "true", "yes")
    data.update(
        OUT_TYPE="hy2",
        OUT_PASSWORD=auth,
        OUT_SNI=q.get("sni", u.hostname or ""),
        OUT_INSECURE="true" if insecure else "false",
        OUT_OBFS=q.get("obfs", ""),
        OUT_OBFS_PASSWORD=q.get("obfs-password", q.get("obfs_password", "")),
    )
    if data["OUT_OBFS"] not in ("", "salamander"):
        fail("当前仅支持 Hysteria2 salamander 混淆")
elif scheme == "tuic":
    uuid = unquote(u.username or "")
    password = unquote(u.password or "")
    if not uuid or not password:
        fail("TUIC 链接缺少 UUID 或认证密码")
    insecure = q.get("allow_insecure", q.get("insecure", "0")).lower() in ("1", "true", "yes")
    data.update(
        OUT_TYPE="tuic",
        OUT_UUID=uuid,
        OUT_PASSWORD=password,
        OUT_SNI=q.get("sni", u.hostname or ""),
        OUT_INSECURE="true" if insecure else "false",
    )
else:
    fail("仅支持 vless://、ss://、socks://、socks5://、hysteria2://、hy2://、tuic:// 链接")

with open(output, "w", encoding="utf-8", newline="\n") as f:
    for key, value in data.items():
        f.write(f"{key}={shlex.quote(str(value))}\n")
PY
  _rc=$?
  [ "$_rc" -eq 0 ] && chmod 600 "$_out"
  return "$_rc"
}

add_node(){
  need_root; init_dirs
  line
  green "添加节点"
  echo " [1] VLESS Reality"
  echo " [2] Shadowsocks"
  echo " [3] SOCKS5"
  echo " [4] Hysteria2"
  echo " [5] TUIC"
  printf "\033[32m请选择 [1]: \033[0m"
  read -r T
  [ -z "$T" ] && T=1
  echo "已选择：$T"
  case "$T" in
    1|2|3)
      if ! command -v xray >/dev/null 2>&1; then
        yellow "未检测到 Xray，正在先安装核心。"
        install_xray || return
      fi
      ;;
    4|5)
      if ! command -v sing-box >/dev/null 2>&1; then
        yellow "未检测到 sing-box，正在先安装核心。"
        install_singbox || return
      fi
      ;;
    *) red "选择无效。"; return ;;
  esac
  ensure_python || { red "需要 python3 才能生成配置。"; return; }
  yellow "正在检测服务器公网 IP..."
  DETECT_IP="$(get_public_ip)"
  if [ -n "$DETECT_IP" ]; then
    green "检测到公网 IP：$DETECT_IP"
  else
    yellow "未检测到公网 IP，请手动输入。"
