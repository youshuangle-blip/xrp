}

install_realm_service(){
  INIT="$(detect_init)"
  REALM_BIN="$(command -v realm || echo /usr/local/bin/realm)"
  if [ "$INIT" = "systemd" ]; then
    cat > /etc/systemd/system/realm.service <<EOF
[Unit]
Description=Realm Port Forward Service
After=network.target

[Service]
User=root
ExecStart=$REALM_BIN -c $REALM_CONF
Restart=always
RestartSec=3
LimitNOFILE=infinity

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable realm >/dev/null 2>&1 || true
  elif [ "$INIT" = "openrc" ]; then
    cat > /etc/init.d/realm <<EOF
#!/sbin/openrc-run

name="realm"
description="Realm Port Forward Service"
command="$REALM_BIN"
command_args="-c $REALM_CONF"
command_background=true
pidfile="/run/realm.pid"
output_log="/var/log/realm.log"
error_log="/var/log/realm.err"

depend() {
    need net
}
EOF
    chmod +x /etc/init.d/realm
    rc-update add realm default >/dev/null 2>&1 || true
  else
    yellow "未识别服务管理器，需手动运行：$REALM_BIN -c $REALM_CONF"
  fi
}

svc_start(){
  INIT="$(detect_init)"
  FOUND=0
  if command -v xray >/dev/null 2>&1 && [ -s "$CONF_FILE" ]; then
    FOUND=1; install_service
    if [ "$INIT" = "systemd" ]; then systemctl restart xray
    elif [ "$INIT" = "openrc" ]; then rc-service xray restart
    else yellow "请手动运行：xray run -config $CONF_FILE"; fi
  fi
  if command -v sing-box >/dev/null 2>&1 && [ -s "$SINGBOX_CONF" ]; then
    FOUND=1; install_singbox_service
    if [ "$INIT" = "systemd" ]; then systemctl restart sing-box
    elif [ "$INIT" = "openrc" ]; then rc-service sing-box restart
    else yellow "请手动运行：sing-box run -c $SINGBOX_CONF"; fi
  fi
  [ "$FOUND" -eq 1 ] || yellow "没有可重启的核心配置。"
}


