  if [ "$INIT" = "systemd" ]; then
    [ "$B" = "1" ] && systemctl enable sing-box || systemctl disable sing-box
  elif [ "$INIT" = "openrc" ]; then
    [ "$B" = "1" ] && rc-update add sing-box default || rc-update del sing-box default
  else
    red "未识别服务管理器。"
  fi
}

sync_time(){
  if command -v chronyd >/dev/null 2>&1; then
    chronyc -a makestep 2>/dev/null || true
  elif command -v ntpd >/dev/null 2>&1; then
    ntpd -q -p pool.ntp.org 2>/dev/null || true
  else
    if command -v apk >/dev/null 2>&1; then apk add --no-cache chrony >/dev/null && rc-service chronyd start 2>/dev/null || true && chronyc -a makestep 2>/dev/null || true
    elif command -v apt-get >/dev/null 2>&1; then apt-get update && apt-get install -y chrony && systemctl restart chrony 2>/dev/null || true; fi
  fi
  green "已尝试同步系统时间。"
}

update_panel(){
  need_root
  TMP="/tmp/xrp-panel-update.$$"
  TARGET="$(command -v xrp 2>/dev/null || true)"
  [ -n "$TARGET" ] || TARGET="/usr/local/bin/xrp"
  yellow "当前版本：$PANEL_VER"
  yellow "正在从 GitHub 下载最新版面板..."
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$PANEL_RAW_URL" -o "$TMP" || { rm -f "$TMP"; red "下载失败：$PANEL_RAW_URL"; return 1; }
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$TMP" "$PANEL_RAW_URL" || { rm -f "$TMP"; red "下载失败：$PANEL_RAW_URL"; return 1; }
  else
    red "需要 curl 或 wget 才能更新面板。"
    return 1
  fi
  if [ ! -s "$TMP" ] || ! head -n1 "$TMP" | grep -q "^#!/bin/sh"; then
    rm -f "$TMP"
    red "下载内容异常，已取消更新。"
    return 1
  fi
  install -m 755 "$TMP" "$TARGET" || { rm -f "$TMP"; red "安装更新失败：$TARGET"; return 1; }
  rm -f "$TMP"
  green "面板已更新：$TARGET"
  yellow "请退出后重新运行 xrp 使用新版本。"
}

uninstall_panel(){
  echo " [1] 仅删除面板"
  echo " [2] 删除面板 + sing-box + 所有配置"
  printf "\033[32m请选择: \033[0m"
  read -r U
  if [ "$U" = "1" ]; then
    rm -f /usr/local/bin/xrp
    green "已删除面板。"
  elif [ "$U" = "2" ]; then
    printf "确认全部删除？输入 yes: "
    read -r C
    [ "$C" = "yes" ] || { yellow "已取消"; return; }
    svc_stop >/dev/null 2>&1 || true
    INIT="$(detect_init)"
    if [ "$INIT" = "systemd" ]; then systemctl disable sing-box >/dev/null 2>&1 || true; rm -f /etc/systemd/system/sing-box.service; systemctl daemon-reload 2>/dev/null || true
    elif [ "$INIT" = "openrc" ]; then rc-update del sing-box default >/dev/null 2>&1 || true; rm -f /etc/init.d/sing-box; fi
    rm -f /usr/local/bin/sing-box /usr/local/bin/xrp
    rm -rf "$CONF_DIR" "$DAT_DIR"
    rm -f /var/log/sing-box.log /var/log/sing-box.err
    green "已删除面板、sing-box 和配置。"
  else
    yellow "已取消。"
  fi
}

