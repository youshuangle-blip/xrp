#!/bin/sh
# Xray 节点管理面板 v4.8
# v4.2 变更：config.json 改由 python3 统一生成（消灭手拼 JSON 漏逗号风险，
#           并减少大量子进程）；apply_config_silent 失败时给出提示而非静默；
#           监听端口查重（节点间 + 系统占用）；选择项做数字校验；
#           只缺 python3 时单独安装而非整套重装。
# v4.3 变更：添加中转时支持解析 ss/socks/vless 节点链接；
#           添加中转后可直接新增或绑定入站节点并设置中转策略。
# v4.4 变更：新增面板脚本自更新菜单，从 GitHub 拉取最新版 xrp。
# v4.5 变更：查看/生成节点链接时同时输出 Clash Meta YAML 配置。
# v4.6 变更：新增 Clash 配置文件生成，减少终端 YAML 输出。
# v4.7 变更：核心从 sing-box 切回 Xray。
# v4.8 变更：新增 Realm 端口转发管理。

set -u

CONF_DIR="/usr/local/etc/xray"
CONF_FILE="$CONF_DIR/config.json"
DAT_DIR="/usr/local/share/xray"
DATA_DIR="$CONF_DIR/xrp"
NODES_DIR="$DATA_DIR/nodes"
RELAYS_DIR="$DATA_DIR/relays"
CLASH_DIR="$DATA_DIR/clash"
REALM_DIR="$DATA_DIR/realm"
REALM_RULES_DIR="$REALM_DIR/rules"
REALM_CONF="$REALM_DIR/config.toml"
PANEL_VER="2026.06.18-v4.8"
PANEL_REPO="youshuangle-blip/xrp"
PANEL_BRANCH="${XRP_BRANCH:-main}"
PANEL_RAW_URL="https://raw.githubusercontent.com/${PANEL_REPO}/${PANEL_BRANCH}/xrp"

red(){ printf "\033[31m%s\033[0m\n" "$*"; }
green(){ printf "\033[32m%s\033[0m\n" "$*"; }
yellow(){ printf "\033[33m%s\033[0m\n" "$*"; }
line(){ printf "\033[32m%s\033[0m\n" "--------------------------------------------------"; }

need_root(){ [ "$(id -u)" -eq 0 ] || { red "请用 root 运行"; exit 1; }; }
init_dirs(){ mkdir -p "$CONF_DIR" "$DAT_DIR" "$DATA_DIR" "$NODES_DIR" "$RELAYS_DIR" "$CLASH_DIR" "$REALM_DIR" "$REALM_RULES_DIR"; }
pause(){ printf "\n按回车继续..."; read -r _; }

ask(){
  _prompt="$1"
  _default="${2:-}"
  if [ -n "$_default" ]; then
    printf "\033[32m%s [%s]: \033[0m" "$_prompt" "$_default" >&2
  else
    printf "\033[32m%s: \033[0m" "$_prompt" >&2
  fi
  read -r _ans
  if [ -z "$_ans" ]; then
    _val="$_default"
    if [ -n "$_default" ]; then
      printf "\033[32m已使用默认值：%s\033[0m\n" "$_val" >&2
    fi
  else
    _val="$_ans"
  fi
  printf "%s" "$_val"
}

ask_required(){
  _prompt="$1"
  _default="${2:-}"
  while true; do
    _val="$(ask "$_prompt" "$_default")"
    if [ -n "$_val" ]; then
      printf "%s" "$_val"
      return
    fi
    red "不能为空，请重新输入。" >&2
    _default=""
  done
}

flush_stdin(){
  while read -r -t 0.05 _junk 2>/dev/null; do :; done || true
}

safe_name(){
  _raw="$1"
  _def="$2"
  case "$_raw" in
    *"cat >"*|*"#!/"*|*"EOF"*|*"XRP"*|*"{"*|*"}"*|*"<"*|*">"*)
      yellow "检测到异常输入，已清理多余粘贴内容。" >&2
      flush_stdin
      _raw="$_def"
      ;;
  esac
  _clean="$(printf "%s" "$_raw" | tr -cd 'A-Za-z0-9._-')"
  [ -n "$_clean" ] || _clean="$_def"
  _clean="$(printf "%s" "$_clean" | cut -c1-32)"
  if [ "$_raw" != "$_clean" ]; then
    yellow "名称已规范为：$_clean" >&2
  fi
  printf "%s" "$_clean"
}

ask_name(){
  _prompt="$1"
  _default="$2"
  _raw="$(ask "$_prompt" "$_default")"
  safe_name "$_raw" "$_default"
}

safe_sni(){
  _raw="$1"
  _def="$2"
  case "$_raw" in
    *"cat >"*|*"#!/"*|*"EOF"*|*"XRP"*|*"{"*|*"}"*|*"<"*|*">"*|*" "*)
      yellow "SNI 输入异常，已恢复默认值。" >&2
      flush_stdin
      _raw="$_def"
      ;;
  esac
  case "$_raw" in
    *.*) printf "%s" "$_raw" ;;
    *) yellow "SNI 格式不像域名，已恢复默认值：$_def" >&2; printf "%s" "$_def" ;;
  esac
}

ask_sni(){
  _prompt="$1"
  _default="$2"
  _raw="$(ask "$_prompt" "$_default")"
  safe_sni "$_raw" "$_default"
}

rand_hex(){
  _n="${1:-16}"
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex "$_n"
  else
    tr -dc 'a-f0-9' < /dev/urandom | head -c $((_n * 2)); echo
  fi
}

rand_port(){
  if command -v od >/dev/null 2>&1; then
    od -An -N2 -tu2 /dev/urandom | awk '{print 10000 + ($1 % 55535)}'
  else
    awk 'BEGIN{srand(); print int(10000 + rand() * 55535)}'
  fi
}

url_encode(){
  python3 - "$1" <<'PY' 2>/dev/null || printf "%s" "$1"
import sys, urllib.parse
print(urllib.parse.quote(sys.argv[1], safe=''))
PY
}

parse_relay_link(){
  _link="$1"
  python3 - "$_link" <<'PY'
import base64
import re
import shlex
import sys
import urllib.parse


def fail(msg):
    print(msg, file=sys.stderr)
    sys.exit(1)


def b64_decode(value):
    value = value.strip()
    value += "=" * ((4 - len(value) % 4) % 4)
    try:
        return base64.urlsafe_b64decode(value.encode()).decode()
    except Exception as exc:
        raise ValueError("base64 解码失败") from exc


def port_of(parsed):
    try:
        return parsed.port
    except ValueError as exc:
        raise ValueError("端口格式无效") from exc


def clean_name(value, fallback):
    value = urllib.parse.unquote(value or "")
    value = re.sub(r"[^A-Za-z0-9._-]", "", value)[:32]
    return value or fallback


def emit(data):
    keys = [
        "LINK_RELAY_TYPE", "LINK_NAME", "LINK_SERVER", "LINK_PORT",
        "LINK_METHOD", "LINK_PASSWORD", "LINK_SOCKS_USER",
        "LINK_UUID", "LINK_SNI", "LINK_PUBLIC_KEY", "LINK_SHORT_ID",
        "LINK_FLOW", "LINK_TRANSPORT", "LINK_SECURITY", "LINK_FINGERPRINT",
        "LINK_WS_HOST", "LINK_WS_PATH", "LINK_SERVICE_NAME", "LINK_ALPN", "LINK_SPIDER_X",
    ]
    for key in keys:
        print(f"{key}={shlex.quote(str(data.get(key, '') or ''))}")


link = sys.argv[1].strip()
parsed = urllib.parse.urlsplit(link)
scheme = parsed.scheme.lower()
if not scheme:
    fail("未识别到链接协议。")

query = urllib.parse.parse_qs(parsed.query, keep_blank_values=True)
query = {k.lower(): (v[-1] if v else "") for k, v in query.items()}


def qget(*names):
    for name in names:
        value = query.get(name.lower())
        if value:
            return value
    return ""


name = clean_name(parsed.fragment, "")

try:
    if scheme == "ss":
        host = parsed.hostname or ""
        port = port_of(parsed)
        userinfo = ""
        method = ""
        password = ""
        if host and port and "@" in parsed.netloc:
            userinfo = urllib.parse.unquote(parsed.netloc.rsplit("@", 1)[0])
            if ":" in userinfo:
                method, password = userinfo.split(":", 1)
            else:
                method, password = b64_decode(userinfo).split(":", 1)
        else:
            token = (parsed.netloc + parsed.path).lstrip("/")
            decoded = b64_decode(token)
            if "@" not in decoded:
                fail("SS 链接缺少服务器地址。")
            auth, endpoint = decoded.rsplit("@", 1)
            if ":" not in auth:
                fail("SS 链接缺少加密方式或密码。")
            method, password = auth.split(":", 1)
            endpoint_parsed = urllib.parse.urlsplit("//" + endpoint)
            host = endpoint_parsed.hostname or ""
            port = port_of(endpoint_parsed)
        if not host or not port or not method:
            fail("SS 链接参数不完整。")
        emit({
            "LINK_RELAY_TYPE": "ss",
            "LINK_NAME": name,
            "LINK_SERVER": host,
            "LINK_PORT": port,
            "LINK_METHOD": urllib.parse.unquote(method),
            "LINK_PASSWORD": urllib.parse.unquote(password),
        })
    elif scheme in ("socks", "socks5", "socks5h"):
        host = parsed.hostname or ""
        port = port_of(parsed)
        if not host or not port:
            fail("SOCKS 链接缺少地址或端口。")
        emit({
            "LINK_RELAY_TYPE": "socks",
            "LINK_NAME": name,
            "LINK_SERVER": host,
            "LINK_PORT": port,
            "LINK_SOCKS_USER": urllib.parse.unquote(parsed.username or ""),
            "LINK_PASSWORD": urllib.parse.unquote(parsed.password or ""),
        })
    elif scheme == "vless":
        host = parsed.hostname or ""
        port = port_of(parsed)
        uuid = urllib.parse.unquote(parsed.username or "")
        if not host or not port or not uuid:
            fail("VLESS 链接缺少 UUID、地址或端口。")
        emit({
            "LINK_RELAY_TYPE": "vless",
            "LINK_NAME": name,
            "LINK_SERVER": host,
            "LINK_PORT": port,
            "LINK_UUID": uuid,
            "LINK_SNI": qget("sni", "servername", "peer"),
            "LINK_PUBLIC_KEY": qget("pbk", "publickey"),
            "LINK_SHORT_ID": qget("sid", "shortid"),
            "LINK_FLOW": qget("flow"),
            "LINK_TRANSPORT": qget("type") or "tcp",
            "LINK_SECURITY": qget("security") or "none",
            "LINK_FINGERPRINT": qget("fp", "fingerprint"),
            "LINK_WS_HOST": qget("host"),
            "LINK_WS_PATH": qget("path"),
            "LINK_SERVICE_NAME": qget("servicename"),
            "LINK_ALPN": qget("alpn"),
            "LINK_SPIDER_X": qget("spx", "spiderx"),
        })
    else:
        fail("暂不支持该链接协议：%s。当前支持 ss://、socks://、socks5://、vless://。" % scheme)
except ValueError as exc:
    fail(str(exc))
PY
}

shell_quote(){
  printf "%s" "$1" | sed "s/'/'\\\\''/g; 1s/^/'/; \$s/\$/'/"
}

detect_init(){
  if command -v systemctl >/dev/null 2>&1 && [ -d /run/systemd/system ]; then
    echo "systemd"
  elif command -v rc-service >/dev/null 2>&1; then
    echo "openrc"
  else
    echo "unknown"
  fi
}

system_name(){
  if [ -f /etc/alpine-release ]; then
    echo "Alpine Linux v$(cat /etc/alpine-release)"
  elif [ -f /etc/os-release ]; then
    . /etc/os-release
    echo "${PRETTY_NAME:-Linux}"
  else
    uname -s
  fi
}

service_running(){
  INIT="$(detect_init)"
  if [ "$INIT" = "systemd" ]; then
    systemctl is-active --quiet xray && echo "已运行" || echo "已停止"
  elif [ "$INIT" = "openrc" ]; then
    rc-service xray status 2>/dev/null | grep -q started && echo "已运行" || echo "已停止"
  else
    pgrep xray >/dev/null 2>&1 && echo "已运行" || echo "已停止"
  fi
}

count_files(){ find "$1" -type f -name '*.env' 2>/dev/null | wc -l | tr -d ' '; }
xray_ver(){ command -v xray >/dev/null 2>&1 && xray version | head -n1 || echo "未安装"; }
realm_ver(){
  if command -v realm >/dev/null 2>&1; then
    _rv="$(realm -v 2>/dev/null || realm --version 2>/dev/null || true)"
    if [ -n "$_rv" ]; then
      printf "%s\n" "$_rv" | head -n1
    else
      echo "已安装"
    fi
    return
  fi
  echo "未安装"
}

realm_running(){
  INIT="$(detect_init)"
  if [ "$INIT" = "systemd" ]; then
    systemctl is-active --quiet realm && echo "已运行" || echo "已停止"
  elif [ "$INIT" = "openrc" ]; then
    rc-service realm status 2>/dev/null | grep -q started && echo "已运行" || echo "已停止"
  else
    pgrep realm >/dev/null 2>&1 && echo "已运行" || echo "已停止"
  fi
}

get_public_ip(){
  for u in "https://api.ipify.org" "https://ipv4.icanhazip.com" "https://ifconfig.me/ip"; do
    ip="$(curl -4 -fsS --max-time 2 "$u" 2>/dev/null | tr -d '\r\n ' || true)"
    case "$ip" in *.*.*.*) echo "$ip"; return ;; esac
  done
  hostname -I 2>/dev/null | awk '{print $1}'
}

gen_uuid(){
  if command -v xray >/dev/null 2>&1; then xray uuid 2>/dev/null && return; fi
  if [ -r /proc/sys/kernel/random/uuid ]; then cat /proc/sys/kernel/random/uuid; else printf "%s-%s-%s-%s-%s\n" "$(rand_hex 4)" "$(rand_hex 2)" "$(rand_hex 2)" "$(rand_hex 2)" "$(rand_hex 6)"; fi
}

gen_x25519(){
  KEYPAIR="$(xray x25519 2>/dev/null || true)"
  PRIVATE_KEY="$(printf "%s\n" "$KEYPAIR" | sed -n 's/^PrivateKey:[[:space:]]*//p; s/^Private key:[[:space:]]*//p' | head -n1)"
  PUBLIC_KEY="$(printf "%s\n" "$KEYPAIR" | sed -n 's/^PublicKey:[[:space:]]*//p; s/^Public key:[[:space:]]*//p; s/^Password (PublicKey):[[:space:]]*//p' | head -n1)"
  [ -n "$PRIVATE_KEY" ] && [ -n "$PUBLIC_KEY" ]
}

ensure_python(){
  command -v python3 >/dev/null 2>&1 && return 0
  yellow "正在安装 python3..." >&2
  if command -v apk >/dev/null 2>&1; then
    apk add --no-cache python3 >/dev/null
  elif command -v apt-get >/dev/null 2>&1; then
    apt-get update >/dev/null && DEBIAN_FRONTEND=noninteractive apt-get install -y python3 >/dev/null
  elif command -v dnf >/dev/null 2>&1; then
    dnf install -y python3 >/dev/null
  elif command -v yum >/dev/null 2>&1; then
    yum install -y python3 >/dev/null
  fi
  command -v python3 >/dev/null 2>&1
}

reset_node_vars(){
  NODE_ID=""; NODE_TAG=""; NODE_TYPE=""; NODE_NAME=""; PUBLIC_HOST=""; LISTEN_PORT=""; EXT_PORT=""
  SNI=""; UUID=""; PRIVATE_KEY=""; PUBLIC_KEY=""; SHORT_ID=""; METHOD=""; PASSWORD=""; SOCKS_USER=""
  NODE_RELAY_MODE="direct"; NODE_RELAY_TAG=""
}

reset_relay_vars(){
  RELAY_ID=""; RELAY_TAG=""; RELAY_TYPE=""; RELAY_NAME=""; SERVER=""; PORT=""; METHOD=""; PASSWORD=""; SOCKS_USER=""
  UUID=""; SNI=""; PUBLIC_KEY=""; SHORT_ID=""; FLOW=""; TRANSPORT=""; SECURITY=""; FINGERPRINT=""; WS_HOST=""; WS_PATH=""; SERVICE_NAME=""; ALPN=""; SPIDER_X=""
}

reset_realm_vars(){
  REALM_ID=""; REALM_NAME=""; REALM_LISTEN_HOST=""; REALM_LISTEN_PORT=""; REALM_REMOTE_HOST=""; REALM_REMOTE_PORT=""; REALM_REMARK=""
}

load_node(){ reset_node_vars; . "$1"; }
load_relay(){ reset_relay_vars; . "$1"; }
load_realm(){ reset_realm_vars; . "$1"; }

install_deps(){
  if command -v apk >/dev/null 2>&1; then
    apk add --no-cache curl wget unzip tar ca-certificates openssl python3 coreutils >/dev/null
  elif command -v apt-get >/dev/null 2>&1; then
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y curl wget unzip tar ca-certificates openssl python3
  elif command -v dnf >/dev/null 2>&1; then
    dnf install -y curl wget unzip tar ca-certificates openssl python3
  elif command -v yum >/dev/null 2>&1; then
    yum install -y curl wget unzip tar ca-certificates openssl python3
  else
    yellow "未识别包管理器，请手动保证 curl/wget/unzip/tar/openssl/python3 可用"
  fi
}

arch_name(){
  case "$(uname -m)" in
    x86_64|amd64) echo "64" ;;
    aarch64|arm64) echo "arm64-v8a" ;;
    armv7l|armv7) echo "arm32-v7a" ;;
    armv6l) echo "arm32-v6" ;;
    armv5tel) echo "arm32-v5" ;;
    i386|i686) echo "32" ;;
    *) red "暂不支持架构：$(uname -m)"; exit 1 ;;
  esac
}

install_xray(){
  need_root; init_dirs; install_deps
  ARCH="$(arch_name)"
  TMP="/tmp/xray-install"
  rm -rf "$TMP"; mkdir -p "$TMP"
  yellow "正在获取 Xray 最新版本..."
  API="$(curl -fsSL --connect-timeout 12 --max-time 20 --retry 2 https://api.github.com/repos/XTLS/Xray-core/releases/latest 2>/dev/null || true)"
  VER="$(printf "%s\n" "$API" | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p' | head -n1)"
  [ -n "$VER" ] || { red "获取版本失败，检查服务器网络能否访问 GitHub。"; return 1; }
  URL="https://github.com/XTLS/Xray-core/releases/download/v${VER}/Xray-linux-${ARCH}.zip"
  yellow "下载：$URL"
  curl -fL --connect-timeout 20 --max-time 120 --retry 2 "$URL" -o "$TMP/xray.zip" || { red "下载失败。"; return 1; }
  unzip -oq "$TMP/xray.zip" -d "$TMP"
  BIN="$(find "$TMP" -type f -name xray | head -n1)"
  [ -n "$BIN" ] || { red "解压后未找到 xray。"; return 1; }
  install -m 755 "$BIN" /usr/local/bin/xray
  [ -f "$TMP/geoip.dat" ] && install -m 644 "$TMP/geoip.dat" "$DAT_DIR/geoip.dat"
  [ -f "$TMP/geosite.dat" ] && install -m 644 "$TMP/geosite.dat" "$DAT_DIR/geosite.dat"
  stop_legacy_singbox
  install_service
  green "Xray 核心安装/更新完成"
  xray version | head -n1
}

realm_arch_patterns(){
  case "$(uname -m)" in
    x86_64|amd64) echo "^realm-x86_64.*linux.*musl ^realm-x86_64.*linux.*gnu ^realm-x86_64.*linux" ;;
    aarch64|arm64) echo "^realm-aarch64.*linux.*musl ^realm-aarch64.*linux.*gnu ^realm-aarch64.*linux" ;;
    armv7l|armv7) echo "^realm-armv7.*linux.*musl ^realm-armv7.*linux.*gnu ^realm-armv7.*linux" ;;
    armv6l) echo "^realm-arm.*linux.*musleabi ^realm-arm.*linux.*gnueabi ^realm-arm.*linux" ;;
    i386|i686) echo "^realm-i686.*linux ^realm-i386.*linux" ;;
    *) red "暂不支持架构：$(uname -m)"; return 1 ;;
  esac
}

install_realm(){
  need_root; init_dirs; install_deps
  TMP="/tmp/realm-install"
  rm -rf "$TMP"; mkdir -p "$TMP"
  yellow "正在获取 Realm 最新版本..."
  API_FILE="$TMP/latest.json"
  curl -fsSL --connect-timeout 12 --max-time 20 --retry 2 https://api.github.com/repos/zhboner/realm/releases/latest -o "$API_FILE" 2>/dev/null || { red "获取版本失败，检查服务器网络能否访问 GitHub。"; return 1; }
  PATTERNS="$(realm_arch_patterns)" || return 1
  URL="$(python3 - "$API_FILE" $PATTERNS <<'PY'
import json, re, sys
path = sys.argv[1]
patterns = sys.argv[2:]
try:
    data = json.load(open(path, encoding="utf-8"))
except Exception:
    sys.exit(1)
assets = data.get("assets") or []
for pat in patterns:
    rx = re.compile(pat, re.I)
    for asset in assets:
        name = asset.get("name") or ""
        url = asset.get("browser_download_url") or ""
        low = name.lower()
        if any(x in low for x in (".sha", ".sig", ".asc", "checksum")):
            continue
        if url and rx.search(name):
            print(url)
            sys.exit(0)
sys.exit(1)
PY
)" || { red "未找到适合当前架构的 Realm Linux 包。"; return 1; }
  yellow "下载：$URL"
  PKG="$TMP/realm.pkg"
  curl -fL --connect-timeout 20 --max-time 120 --retry 2 "$URL" -o "$PKG" || { red "下载失败。"; return 1; }
  case "$URL" in
    *.tar.gz|*.tgz) tar -xzf "$PKG" -C "$TMP" ;;
    *.tar.xz|*.txz) tar -xJf "$PKG" -C "$TMP" ;;
    *.zip) unzip -oq "$PKG" -d "$TMP" ;;
    *.gz) gzip -dc "$PKG" > "$TMP/realm" ;;
    *) cp "$PKG" "$TMP/realm" ;;
  esac
  BIN="$(find "$TMP" -type f -name realm | head -n1)"
  [ -n "$BIN" ] || { red "解压后未找到 realm。"; return 1; }
  install -m 755 "$BIN" /usr/local/bin/realm
  /usr/local/bin/realm -v >/dev/null 2>&1 || /usr/local/bin/realm --version >/dev/null 2>&1 || { red "Realm 已下载但无法运行，可能是架构或系统不兼容。"; return 1; }
  install_realm_service
  green "Realm 安装/更新完成"
  realm_ver
}

install_service(){
  INIT="$(detect_init)"
  XRAY_BIN="$(command -v xray || echo /usr/local/bin/xray)"
  if [ "$INIT" = "systemd" ]; then
    cat > /etc/systemd/system/xray.service <<EOF
[Unit]
Description=Xray Service
After=network.target nss-lookup.target

[Service]
User=root
ExecStart=$XRAY_BIN run -config $CONF_FILE
Restart=always
RestartSec=3
LimitNOFILE=infinity

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable xray >/dev/null 2>&1 || true
  elif [ "$INIT" = "openrc" ]; then
    cat > /etc/init.d/xray <<EOF
#!/sbin/openrc-run

name="xray"
description="Xray Service"
command="$XRAY_BIN"
command_args="run -config $CONF_FILE"
command_background=true
pidfile="/run/xray.pid"
output_log="/var/log/xray.log"
error_log="/var/log/xray.err"

depend() {
    need net
    after firewall
}
EOF
    chmod +x /etc/init.d/xray
    rc-update add xray default >/dev/null 2>&1 || true
  else
    yellow "未识别服务管理器，需手动运行：xray run -config $CONF_FILE"
  fi
}

install_realm_service(){
  INIT="$(detect_init)"
  REALM_BIN="$(command -v realm || echo /usr/local/bin/realm)"
  if [ "$INIT" = "systemd" ]; then
    cat > /etc/systemd/system/realm.service <<EOF
[Unit]
Description=Realm Port Forward Service
After=network.target

[Service]
User=root
ExecStart=$REALM_BIN -c $REALM_CONF
Restart=always
RestartSec=3
LimitNOFILE=infinity

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable realm >/dev/null 2>&1 || true
  elif [ "$INIT" = "openrc" ]; then
    cat > /etc/init.d/realm <<EOF
#!/sbin/openrc-run

name="realm"
description="Realm Port Forward Service"
command="$REALM_BIN"
command_args="-c $REALM_CONF"
command_background=true
pidfile="/run/realm.pid"
output_log="/var/log/realm.log"
error_log="/var/log/realm.err"

depend() {
    need net
}
EOF
    chmod +x /etc/init.d/realm
    rc-update add realm default >/dev/null 2>&1 || true
  else
    yellow "未识别服务管理器，需手动运行：$REALM_BIN -c $REALM_CONF"
  fi
}

